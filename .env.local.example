# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and stays on your machine.
# For production, add these as environment variables in Vercel project settings.

# Resend API key — used by the contact form server action to send emails.
# Sign up at https://resend.com (free tier: 100 emails/day, 3,000/month)
# Dashboard > API Keys > Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# --- After signing up for Resend ---
# 1. Add and verify your domain (mastertech.work) in Resend > Domains
# 2. Update FROM_EMAIL in src/app/actions/contact.ts from
#    "onboarding@resend.dev" to e.g. "MasterTech <noreply@mastertech.work>"
# 3. Add RESEND_API_KEY to Vercel: Project Settings > Environment Variables
#    (add it to Production, Preview, and Development)
